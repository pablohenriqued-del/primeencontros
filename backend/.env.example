# Copiar pra "backend/.env" (nunca commitar o real) e preencher. Injetado no
# container via `env_file:` no docker-compose.yml — vira variável de
# ambiente do processo uvicorn, lida por os.environ em server.py.

# Postgres compartilhado da VPS — container noxsystems_postgres-db (não é um
# container próprio do primeencontros). Banco/usuário dedicados, criados uma
# vez à mão antes do primeiro deploy — ver .ai/docs/DEPLOY.md seção "Antes do
# primeiro deploy". Trocar "noxsystems_postgres-db" pelo nome real do
# container se for diferente na VPS.
DATABASE_URL=postgresql://primeencontros:TROCAR_SENHA@noxsystems_postgres-db:5432/primeencontros

# Stripe (SDK oficial — ver .ai/context/CONTRACTS.md #9)
STRIPE_API_KEY=sk_test_ou_sk_live_...
# Gerado no dashboard do Stripe ao criar o endpoint do webhook
# (https://dashboard.stripe.com/webhooks) apontando pra
# https://api.primeencontros.com/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Ainda depende da infra da Emergent (Object Storage de fotos/vídeo) —
# decisão consciente de manter por enquanto, ver CONTRACTS.md #10
EMERGENT_LLM_KEY=

# Emails que sempre viram admin no login (separados por vírgula).
# Se vazio, só o primeiro usuário a logar vira admin.
ADMIN_EMAILS=
