# Fica ao lado do docker-compose.yml (ex: /opt/primeencontros/.env). Só é lido
# pelo `docker compose` pra resolver ${REACT_APP_BACKEND_URL} no build do
# frontend — não é injetado em nenhum container em runtime. Copiar pra ".env"
# e preencher antes de rodar `docker compose build`.

REACT_APP_BACKEND_URL=https://api.primeencontros.com
